# ============================================================
# BidIQ Pro — Frontend Environment Variables (Vite)
# Copy this file to .env.local and fill in your values.
# All VITE_ vars are bundled into the client — do NOT put
# secrets here. Only safe public values.
# ============================================================

# ── App Identity ─────────────────────────────────────────────
VITE_APP_NAME="BidIQ Pro"
VITE_APP_URL=http://localhost:5173

# ── API ──────────────────────────────────────────────────────
# Points to your backend. In production, set to your Render API URL.
VITE_API_URL=http://localhost:3001

# ── Feature Flags ────────────────────────────────────────────
# Set to true to show demo banner and use seeded demo data
VITE_DEMO_MODE=true

# ── Stripe (Public Key only) ─────────────────────────────────
# Safe to expose — publishable key only, never the secret key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
