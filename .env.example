# ============================================================
# BidIQ Pro — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# ── General ─────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="BidIQ Pro"
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3000
PORT=3000

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://bidiq:password@localhost:5432/bidiq_dev

# ── Authentication ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-min-64-chars-change-this-before-deploy
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-64-chars-change-this
SESSION_SECRET=your-session-secret-min-64-chars-change-this
BCRYPT_ROUNDS=12

# ── OpenAI / AI ─────────────────────────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── Tender Sources ──────────────────────────────────────────
# Contracts Finder: https://www.contractsfinder.service.gov.uk/
CONTRACTS_FINDER_API_KEY=your-contracts-finder-api-key

# Find a Tender: https://www.findatender.service.gov.uk/
FIND_A_TENDER_API_KEY=your-find-a-tender-api-key

# National Highways published tenders (public RSS/API)
NATIONAL_HIGHWAYS_SOURCE_URL=https://highwaysengland.co.uk/procurement/

# Comma-separated local authority procurement portals
LOCAL_AUTHORITY_SOURCE_URLS=https://www.yortender.co.uk,https://www.procontract.due-north.com

# ── Search (MeiliSearch) ─────────────────────────────────────
# Run locally: docker run -p 7700:7700 getmeili/meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# ── File Storage ─────────────────────────────────────────────
# Compatible with AWS S3, Cloudflare R2, MinIO, Supabase Storage
S3_ENDPOINT=https://your-bucket.s3.eu-west-2.amazonaws.com
S3_BUCKET=bidiq-uploads
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_REGION=eu-west-2

# ── Email (Resend) ───────────────────────────────────────────
# Get key at: https://resend.com
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@bidiqpro.com

# ── Stripe ───────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/developers
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create prices in Stripe dashboard and paste IDs here
STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_GROWTH=price_growth_id_here
STRIPE_PRICE_PROFESSIONAL=price_professional_id_here
STRIPE_PRICE_ENTERPRISE=price_enterprise_id_here

# ── Security ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Demo Mode ────────────────────────────────────────────────
# Set to true to use seeded demo data when real API keys are missing
DEMO_MODE=true
